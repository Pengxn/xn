{
    "version": "1.29.0",
    "homepage": "https://github.com/rust-lang/rustup",
    "description": "Manage multiple rust installations with ease",
    "license": "MIT|Apache-2.0",
    "persist": [
        ".cargo",
        ".rustup",
        ".cargo-install"
    ],
    "env_add_path": [
        ".cargo\\bin",
        ".cargo-install\\bin"
    ],
    "env_set": {
        "CARGO_HOME": "$dir\\.cargo",
        "RUSTUP_HOME": "$dir\\.rustup",
        "CARGO_INSTALL_ROOT": "$dir\\.cargo-install"
    },
    "architecture": {
        "64bit": {
            "url": "https://static.rust-lang.org/rustup/archive/1.29.0/x86_64-pc-windows-gnu/rustup-init.exe",
            "hash": "03dbaae1d33a4d220bd0d202e5092955dae859c119074192ca513f8c4713fff7"
        }
    },
    "checkver": {
        "url": "https://sh.rustup.rs",
        "regex": "rustup-init ([\\d.]+) \\("
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://static.rust-lang.org/rustup/archive/$version/x86_64-pc-windows-gnu/rustup-init.exe"
            }
        },
        "hash": {
            "url": "$url.sha256"
        }
    },
    "post_install": [
        "# Create environment variables for this process",
        "[Environment]::SetEnvironmentVariable('CARGO_HOME', \"$persist_dir\\.cargo\", 'Process')",
        "[Environment]::SetEnvironmentVariable('RUSTUP_HOME', \"$persist_dir\\.rustup\", 'Process')"
    ],
    "notes": [
        "To use the MSVC ABI without Visual Studio 2015 (or higher) installed,",
        "you will need the Microsoft C++ Build Tools:",
        "https://visualstudio.microsoft.com/visual-cpp-build-tools/",
        "You can install rust with MSVC by running:",
        "& \"$dir\\rustup-init.exe\" -y --no-modify-path",
        "You can install rust with GNU by running:",
        "& \"$dir\\rustup-init.exe\" -y --no-modify-path --default-host x86_64-pc-windows-gnu"
    ]
}
